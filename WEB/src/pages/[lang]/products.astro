---
import '../../styles/global.css';
import ProductCard from '../../components/ProductCard.astro';
import siteData from '../../data/b2b-site.json';

export function getStaticPaths() {
	return [
		{ params: { lang: 'en' } },
		{ params: { lang: 'zh' } }
	];
}

const lang = Astro.params.lang === 'zh' ? 'zh' : 'en';
const locale = siteData[lang];
const switchLang = lang === 'zh' ? 'en' : 'zh';
const switchLabel = siteData[switchLang].nav.language;
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{locale.siteName} · {locale.nav.products}</title>
	</head>

	<body class="bg-slate-50 text-slate-900">
		<div class="mx-auto max-w-6xl px-6 py-8 sm:px-8 lg:px-12">
			<nav class="mb-10 flex flex-wrap items-center justify-between gap-4">
				<div class="space-x-4 text-sm font-medium text-slate-700">
					<a href={`/${lang}/`} class="hover:text-slate-900">{locale.nav.home}</a>
					<a href={`/${lang}/products`} class="text-slate-900">{locale.nav.products}</a>
				</div>
				<a href={`/${switchLang}/`} class="rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-900 transition hover:bg-slate-100">{switchLabel}</a>
			</nav>

			<header class="mb-14 rounded-[2rem] bg-white px-8 py-12 shadow-sm sm:px-12">
				<h1 class="text-3xl font-semibold text-slate-900 sm:text-4xl">{locale.products.partBasedTitle}</h1>
				<p class="mt-4 text-slate-600">{locale.products.partBasedDescription}</p>
			</header>

			<section class="grid gap-6 md:grid-cols-2">
				{locale.products.items.filter((item) => item.type === 'part').map((item) => (
					<ProductCard item={item} />
				))}
			</section>

			<section class="mt-20 rounded-[2rem] bg-white px-8 py-12 shadow-sm sm:px-12">
				<h2 class="text-3xl font-semibold text-slate-900">{locale.products.modelBasedTitle}</h2>
				<p class="mt-4 text-slate-600">{locale.products.modelBasedDescription}</p>
				<div class="mt-10 grid gap-6 md:grid-cols-2">
					{locale.products.items.filter((item) => item.type === 'model').map((item) => (
						<ProductCard item={item} />
					))}
				</div>
			</section>

			<section class="mt-20 rounded-[2rem] bg-slate-950 px-8 py-12 text-white shadow-2xl sm:px-12">
				<h2 class="text-3xl font-semibold">{locale.contact.headline}</h2>
				<p class="mt-4 text-slate-300">{locale.contact.description}</p>
				<div class="mt-8 grid gap-6 sm:grid-cols-2">
					<div class="rounded-3xl bg-slate-900/80 p-6">
						<p class="text-sm uppercase tracking-[0.35em] text-emerald-300">Email</p>
						<p class="mt-3 text-lg font-semibold text-white">{locale.contact.email}</p>
					</div>
					<div class="rounded-3xl bg-slate-900/80 p-6">
						<p class="text-sm uppercase tracking-[0.35em] text-emerald-300">{lang === 'zh' ? '电话' : 'Phone'}</p>
						<p class="mt-3 text-lg font-semibold text-white">{locale.contact.phone}</p>
					</div>
				</div>
			</section>
		</div>
	</body>
</html>
