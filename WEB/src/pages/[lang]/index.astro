---
import '../../styles/global.css';
import ServiceCard from '../../components/ServiceCard.astro';
import siteData from '../../data/b2b-site.json';

export function getStaticPaths() {
	return [
		{ params: { lang: 'en' } },
		{ params: { lang: 'zh' } }
	];
}

const lang = Astro.params.lang === 'zh' ? 'zh' : 'en';
const locale = siteData[lang];
const switchLang = lang === 'zh' ? 'en' : 'zh';
const switchLabel = siteData[switchLang].nav.language;
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{locale.siteName}</title>
	</head>

	<body class="bg-slate-50 text-slate-900">
		<div class="mx-auto max-w-6xl px-6 py-8 sm:px-8 lg:px-12">
			<header class="mb-14 flex flex-col gap-6 rounded-[2rem] bg-slate-950 px-8 py-10 text-white shadow-2xl sm:px-12">
				<div class="flex flex-wrap items-center justify-between gap-4">
					<div>
						<p class="text-sm uppercase tracking-[0.35em] text-slate-400">B2B Inquiry</p>
						<h1 class="mt-4 text-4xl font-semibold sm:text-5xl">{locale.hero.title}</h1>
						<p class="mt-6 max-w-3xl text-base leading-8 text-slate-300">{locale.hero.subtitle}</p>
						<p class="mt-4 max-w-2xl text-slate-400">{locale.hero.description}</p>
					</div>
					<a href={`/${switchLang}/`} class="rounded-full border border-white/20 bg-white/10 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/20">{switchLabel}</a>
				</div>
				<div class="mt-8 flex flex-wrap gap-4">
					<a href={`/${lang}/products`} class="inline-flex items-center justify-center rounded-full bg-emerald-400 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-400/10 transition hover:bg-emerald-300">{locale.hero.cta}</a>
					<a href={`#contact`} class="inline-flex items-center justify-center rounded-full border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/20">{locale.nav.contact}</a>
				</div>
			</header>

			<section class="grid gap-6 md:grid-cols-3">
				{locale.services.map((service) => (
					<ServiceCard title={service.title} subtitle={service.subtitle} description={service.description} icon={service.icon} />
				))}
			</section>

			<section id="contact" class="mt-20 rounded-[2rem] bg-white px-8 py-12 shadow-sm sm:px-12">
				<h2 class="text-3xl font-semibold text-slate-900">{locale.contact.headline}</h2>
				<p class="mt-4 text-slate-600">{locale.contact.description}</p>
				<div class="mt-8 grid gap-6 sm:grid-cols-2">
					<div class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
						<p class="text-sm uppercase tracking-[0.35em] text-slate-500">Email</p>
						<p class="mt-3 text-lg font-semibold text-slate-900">{locale.contact.email}</p>
					</div>
					<div class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
						<p class="text-sm uppercase tracking-[0.35em] text-slate-500">{lang === 'zh' ? '电话' : 'Phone'}</p>
						<p class="mt-3 text-lg font-semibold text-slate-900">{locale.contact.phone}</p>
					</div>
				</div>
				<div class="mt-10 rounded-3xl border border-slate-200 bg-slate-950 p-8 text-white">
					<p class="text-sm uppercase tracking-[0.35em] text-emerald-300">Inquiry</p>
					<p class="mt-4 text-slate-200">{lang === 'zh' ? '请把您要询盘的零件编号/机型、数量与交付要求发送给我们。' : 'Send us the part number/model, quantity, and delivery requirements for a fast quote.'}</p>
				</div>
			</section>
		</div>
	</body>
</html>
