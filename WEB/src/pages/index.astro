---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Acme B2B Inquiry</title>
	</head>

	<body class="bg-slate-50 text-slate-900">
		<div class="mx-auto flex min-h-screen max-w-5xl flex-col items-center justify-center gap-8 px-6 py-12 text-center sm:px-8">
			<div class="rounded-[2rem] bg-white px-8 py-12 shadow-2xl sm:px-12">
				<p class="text-sm uppercase tracking-[0.35em] text-slate-500">B2B Inquiry Website</p>
				<h1 class="mt-6 text-4xl font-semibold text-slate-950 sm:text-5xl">Multi-language laptop parts inquiry</h1>
				<p class="mt-6 max-w-2xl text-base leading-8 text-slate-600">Choose a language and browse product pages by part number/parameter or computer model like HP 840 G3 BATTERY.</p>
				<div class="mt-10 grid gap-4 sm:grid-cols-2">
					<a href="/en/" class="rounded-3xl bg-slate-950 px-8 py-4 text-sm font-semibold text-white transition hover:bg-slate-800">English Site</a>
					<a href="/zh/" class="rounded-3xl border border-slate-200 bg-white px-8 py-4 text-sm font-semibold text-slate-950 transition hover:bg-slate-100">中文站点</a>
				</div>
			</div>
			<p class="max-w-md text-sm text-slate-500">The site includes products by part number/spec and by computer model, with a bilingual inquiry flow.</p>
		</div>
	</body>
</html>
