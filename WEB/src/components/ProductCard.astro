---
const { item } = Astro.props;
---
<div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
	<div class="mb-3 flex items-center justify-between gap-4">
		<h3 class="text-xl font-semibold text-slate-900">{item.title}</h3>
		<span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">{item.stock}</span>
	</div>

	{item.type === 'part' ? (
		<>
			<p class="text-sm text-slate-600">Part No: <span class="font-medium text-slate-900">{item.partNumber}</span></p>
			<p class="mt-3 text-sm text-slate-600">{item.note}</p>
			<div class="mt-4 space-y-1 text-sm text-slate-600">
				{item.parameters.map((param) => (
					<p>• {param}</p>
				))}
			</div>
		</>
	) : (
		<>
			<p class="text-sm text-slate-600">Model: <span class="font-medium text-slate-900">{item.model}</span></p>
			<p class="mt-3 text-sm text-slate-600">{item.description}</p>
			<div class="mt-4 space-y-1 text-sm text-slate-600">
				<p class="font-semibold text-slate-900">Compatibility:</p>
				{item.compatibility.map((model) => (
					<p>• {model}</p>
				))}
			</div>
		</>
	)}
</div>
