---
const { title, subtitle, description, icon } = Astro.props;
---
<div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
  <div class="mb-4 text-3xl">{icon}</div>
  <h3 class="text-xl font-semibold text-slate-900">{title}</h3>
  <p class="mt-1 text-sm font-medium text-slate-500">{subtitle}</p>
  <p class="mt-4 text-slate-600">{description}</p>
</div>
